# === Telegram Bot ===
BOT_TOKEN=your_bot_token_from_botfather

# === OpenAI ===
OPENAI_API_KEY=your_openai_api_key

# === Google Sheets ===
SPREADSHEET_ID=your_spreadsheet_id_from_url
GOOGLE_CREDS_FILE=credentials.json

# === Контроль доступа (опционально) ===
# Список разрешённых user_id через запятую (оставьте пустым для открытого доступа)
ALLOWED_USERS=
# Список администраторов через запятую
ADMIN_IDS=

# === Настройки LLM (опционально) ===
LLM_MODEL=gpt-3.5-turbo
LLM_TEMPERATURE=0.8
LLM_MAX_TOKENS=1000
